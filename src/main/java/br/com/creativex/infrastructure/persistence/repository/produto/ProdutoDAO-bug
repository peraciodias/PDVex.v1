// Peracio Dias - Creativex Sistemas
package br.com.creativex.infrastructure.persistence.repository.produto;

import br.com.creativex.domain.entity.produto.Produto;
import br.com.creativex.domain.transaction.Transaction;
import java.sql.*;
import java.math.BigDecimal;
import java.util.ArrayList;
import java.util.List;

public class ProdutoDAO {
    private final Transaction tx;

    public ProdutoDAO(Transaction tx) {
        this.tx = tx;
    }

    // ============================================================
    // CONSULTAS (Utilizam a VIEW para trazer cálculos fiscais)
    // ============================================================

    public Produto buscarPorId(long id) {
        return tx.execute(conn -> {
            String sql = "SELECT * FROM public.vw_pdv_bipagem WHERE id = ?";
            try (PreparedStatement ps = conn.prepareStatement(sql)) {
                ps.setLong(1, id);
                try (ResultSet rs = ps.executeQuery()) {
                    return rs.next() ? mapear(rs) : null;
                }
            }
        });
    }

    public Produto buscarPorCodigoBarra(String codigo) {
        return tx.execute(conn -> {
            String sql = "SELECT * FROM public.vw_pdv_bipagem WHERE codigo_barra = ? LIMIT 1";
            try (PreparedStatement ps = conn.prepareStatement(sql)) {
                ps.setString(1, codigo);
                try (ResultSet rs = ps.executeQuery()) {
                    return rs.next() ? mapear(rs) : null;
                }
            }
        });
    }

    public Produto buscarPorNome(String nome) {
        return tx.execute(conn -> {
            String sql = "SELECT * FROM public.vw_pdv_bipagem WHERE descricao ILIKE ? ORDER BY id LIMIT 1";
            try (PreparedStatement ps = conn.prepareStatement(sql)) {
                ps.setString(1, "%" + nome + "%");
                try (ResultSet rs = ps.executeQuery()) {
                    return rs.next() ? mapear(rs) : null;
                }
            }
        });
    }

    public List<Produto> listarPorIdLimite(long idInicial, int limite) {
        return tx.execute(conn -> {
            String sql = "SELECT * FROM public.vw_pdv_bipagem WHERE id >= ? ORDER BY id LIMIT ?";
            List<Produto> lista = new ArrayList<>();
            try (PreparedStatement ps = conn.prepareStatement(sql)) {
                ps.setLong(1, idInicial);
                ps.setInt(2, limite);
                try (ResultSet rs = ps.executeQuery()) {
                    while (rs.next()) lista.add(mapear(rs));
                }
            }
            return lista;
        });
    }

    public Produto buscarUltimo() {
        return tx.execute(conn -> {
            String sql = "SELECT * FROM public.vw_pdv_bipagem ORDER BY id DESC LIMIT 1";
            try (PreparedStatement ps = conn.prepareStatement(sql)) {
                try (ResultSet rs = ps.executeQuery()) {
                    return rs.next() ? mapear(rs) : null;
                }
            }
        });
    }

    public Produto buscarPorCodigoOuId(String filtro) {
        if (filtro == null || filtro.isBlank()) return null;
        Produto p = buscarPorCodigoBarra(filtro);
        if (p != null) return p;
        if (filtro.matches("\\d+")) {
            return buscarPorId(Long.parseLong(filtro));
        }
        return buscarPorNome(filtro);
    }

    // ============================================================
    // OPERAÇÕES DE DADOS (Utilizam a TABELA real)
    // ============================================================

    public void inserir(Produto p) {
        tx.execute(conn -> {
            String sql = """
                INSERT INTO tabela_produtos (
                    codigo_barra, origem, descricao, marca, atributos, unidade_medida, categoria,
                    cod_grupo, grupo, tipo_balanca, quantidade_estoque, preco_custo, preco_venda,
                    ncm, cest, cfop_padrao, unidade_tributavel, cean_tributavel,
                    cst_icms, aliquota_icms, cst_pis, ppis, cst_cofins, pcofins, loja
                ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
                """;
            try (PreparedStatement stmt = conn.prepareStatement(sql)) {
                preencherStatement(stmt, p);
                stmt.executeUpdate();
            }
            return null;
        });
    }

    public void atualizar(Produto p) {
        tx.execute(conn -> {
            String sql = """
                UPDATE tabela_produtos SET
                    codigo_barra=?, origem=?, descricao=?, marca=?, atributos=?, unidade_medida=?,
                    categoria=?, cod_grupo=?, grupo=?, tipo_balanca=?, quantidade_estoque=?,
                    preco_custo=?, preco_venda=?, ncm=?, cest=?, cfop_padrao=?, unidade_tributavel=?,
                    cean_tributavel=?, cst_icms=?, aliquota_icms=?, cst_pis=?, ppis=?,
                    cst_cofins=?, pcofins=?, loja=? WHERE id=?
                """;
            try (PreparedStatement stmt = conn.prepareStatement(sql)) {
                preencherStatement(stmt, p);
                stmt.setLong(26, p.getId());
                stmt.executeUpdate();
            }
            return null;
        });
    }

    public void registrarVenda(long idProduto, BigDecimal qtd, long idUsuario) {
        tx.execute(conn -> {
            String sqlUpdate = "UPDATE tabela_produtos SET quantidade_estoque = quantidade_estoque - ? WHERE id = ?";
            String sqlInsert = "INSERT INTO TABELA_MOVIMENTACOES_ESTOQUE (id_produto, tipo, quantidade, motivo, id_usuario) VALUES (?, 'SAIDA', ?, 'Venda PDV', ?)";
            try (PreparedStatement stU = conn.prepareStatement(sqlUpdate)) {
                stU.setBigDecimal(1, qtd); stU.setLong(2, idProduto); stU.executeUpdate();
            }
            try (PreparedStatement stI = conn.prepareStatement(sqlInsert)) {
                stI.setLong(1, idProduto); stI.setBigDecimal(2, qtd); stI.setLong(3, idUsuario); stI.executeUpdate();
            }
            return null;
        });
    }

    public void excluir(long id) {
        tx.execute(conn -> {
            try (PreparedStatement stmt = conn.prepareStatement("DELETE FROM tabela_produtos WHERE id = ?")) {
                stmt.setLong(1, id); stmt.executeUpdate();
            }
            return null;
        });
    }

    // ============================================================
    // MAPEAMENTO E AUXILIARES
    // ============================================================

    private void preencherStatement(PreparedStatement stmt, Produto p) throws SQLException {
        stmt.setString(1, p.getCodigoBarra());
        stmt.setString(2, p.getOrigem());
        stmt.setString(3, p.getDescricao());
        stmt.setString(4, p.getMarca());
        stmt.setString(5, p.getAtributos());
        stmt.setString(6, p.getUnidadeMedida());
        stmt.setString(7, p.getCategoria());
        stmt.setInt(8, p.getCodGrupo());
        stmt.setString(9, p.getGrupo());
        stmt.setString(10, p.getTipoBalanca() == 0 ? null : String.valueOf(p.getTipoBalanca()));
        stmt.setBigDecimal(11, p.getQuantidadeEstoque());
        stmt.setBigDecimal(12, p.getPrecoCusto());
        stmt.setBigDecimal(13, p.getPrecoVenda());
        stmt.setString(14, p.getNcm());
        stmt.setString(15, p.getCest());
        stmt.setString(16, p.getCfopPadrao());
        stmt.setString(17, p.getUnidadeTributavel());
        stmt.setString(18, p.getCeanTributavel());
        stmt.setString(19, p.getCstIcms());
        stmt.setBigDecimal(20, p.getAliquotaIcms());
        stmt.setString(21, p.getCstPis());
        stmt.setBigDecimal(22, p.getPpis());
        stmt.setString(23, p.getCstCofins());
        stmt.setBigDecimal(24, p.getPcofins());
        stmt.setString(25, p.getLoja());
    }

    private Produto mapear(ResultSet rs) throws SQLException {
        Produto p = new Produto();
        p.setId(rs.getLong("id"));
        p.setCodigoBarra(rs.getString("codigo_barra"));
        p.setDescricao(rs.getString("descricao"));
        p.setMarca(rs.getString("marca"));
        p.setAtributos(rs.getString("atributos"));
        p.setUnidadeMedida(rs.getString("unidade_medida"));
        p.setCategoria(rs.getString("categoria"));
        p.setCodGrupo(rs.getInt("cod_grupo"));
        p.setGrupo(rs.getString("grupo"));

        String tb = rs.getString("tipo_balanca");
        if (tb != null && !tb.isEmpty()) p.setTipoBalanca(tb.charAt(0));

        p.setQuantidadeEstoque(rs.getBigDecimal("quantidade_estoque"));
        p.setPrecoCusto(rs.getBigDecimal("preco_custo"));
        p.setPrecoVenda(rs.getBigDecimal("preco_venda"));
        p.setNcm(rs.getString("ncm"));
        p.setCest(rs.getString("cest"));
        p.setCfopPadrao(rs.getString("cfop_padrao"));
        p.setUnidadeTributavel(rs.getString("unidade_tributavel"));
        p.setCeanTributavel(rs.getString("cean_tributavel"));
        p.setCstIcms(rs.getString("cst_icms"));
        p.setAliquotaIcms(rs.getBigDecimal("aliquota_icms"));
        p.setCstPis(rs.getString("cst_pis"));
        p.setPpis(rs.getBigDecimal("ppis"));
        p.setCstCofins(rs.getString("cst_cofins"));
        p.setPcofins(rs.getBigDecimal("pcofins"));
        p.setDataCadastro(rs.getTimestamp("data_cadastro"));
        p.setLoja(rs.getString("loja"));

        // Campos extras da VIEW
        try {
            p.setAliquotaAplicada(rs.getBigDecimal("aliquota_applied")); // use o nome real da coluna na view
            p.setValorImpostoItem(rs.getBigDecimal("valor_imposto_item"));
        } catch (SQLException ignored) {}

        return p;
    }
}